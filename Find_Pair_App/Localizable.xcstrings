    "about_text_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A memory like a goldfish? Find out!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Tienes memoria de pez? ¡Descúbrelo!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une mémoire de poisson rouge ? Découvrez-le !"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आपकी याददाश्त गोल्डफ़िश जैसी है? पता लगाएँ!"
          }
        },
        "ru-RU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Память как у золотой рыбки? Проверьте!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "记忆力像金鱼一样差？来测测看！"
          }
        }
      }
    },
    "about_text_2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Everyone here has a partner."
